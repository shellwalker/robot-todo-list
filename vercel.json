{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/robot-todo-list/static/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/robot-todo-list/manifest.json",
      "dest": "/robot-todo-list/manifest.json"
    },
    {
      "src": "/robot-todo-list/favicon.ico",
      "dest": "/robot-todo-list/favicon.ico"
    },
    {
      "src": "/robot-todo-list/logo192.png",
      "dest": "/robot-todo-list/logo192.png"
    },
    {
      "src": "/robot-todo-list/logo512.png",
      "dest": "/robot-todo-list/logo512.png"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "regions": ["iad1"]
}
